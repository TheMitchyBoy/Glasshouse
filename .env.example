# =============================================================================
# Glasshouse — Environment Configuration
# Copy this file to .env and fill in your values.
# On Railway, set these as service variables instead.
# =============================================================================

# --- Database (required) -------------------------------------------------------
# PostgreSQL connection to your YouTube meeting transcript database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/youtube_transcripts

# --- LLM providers (at least one required) -------------------------------------
# Anthropic direct API (preferred). Model uses hyphens: claude-sonnet-4-5
ANTHROPIC_API_KEY=

# OpenRouter proxy for Claude. Model uses dots: anthropic/claude-sonnet-4.5
OPENROUTER_API_KEY=

# OpenAI fallback if Claude providers fail or are unavailable.
OPENAI_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Telegram ------------------------------------------------------------------
# Create a bot via @BotFather, then get your chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Pipeline tuning -----------------------------------------------------------
LOOKBACK_DAYS=14              # How many days back to fetch meetings
MAX_TRANSCRIPTS=10           # Max meetings per analysis run
MAX_RESEARCH_QUERIES=3       # Web searches per video idea
MAX_TRANSCRIPT_CHARS=6000    # Chars sent to LLM per transcript
LLM_MAX_TOKENS=8192          # Max tokens in LLM response
DRY_RUN=false

# --- Daily automation ----------------------------------------------------------
DAILY_SCAN_ENABLED=true      # Scan for new meetings daily (via dashboard)
DAILY_SCAN_HOUR=8            # Hour to run scan (24h clock)
DAILY_SCAN_MINUTE=0
DAILY_SCAN_TIMEZONE=UTC      # e.g. America/New_York
TELEGRAM_POLLING_ENABLED=true  # Listen for Telegram commands and Q&A

# --- Telegram AI agent ---------------------------------------------------------
AGENT_MAX_HISTORY=8          # Conversation turns remembered per chat
AGENT_CONTEXT_CHARS=8000     # Transcript chars included in agent context

# --- Security (recommended for production) ---------------------------------------
ENV=development              # Set to production on Railway
API_SECRET_KEY=              # Required when ENV=production; protects /api/* routes
CORS_ORIGINS=                # Comma-separated allowed origins (e.g. https://your-app.railway.app)
RATE_LIMIT_ANALYZE_PER_MINUTE=5
RATE_LIMIT_SCAN_PER_MINUTE=2
